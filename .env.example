# ── Bullhorn Credentials ───────────────────────────────────────────────
# Get these from your Bullhorn API application (or request from Bullhorn Support)
BULLHORN_CLIENT_ID=your_client_id_here
BULLHORN_CLIENT_SECRET=your_client_secret_here
BULLHORN_USERNAME=your_bullhorn_login_email
BULLHORN_PASSWORD=your_bullhorn_password

# ── Optional: AI Email Drafts ──────────────────────────────────────────
# If set, email drafts will be generated by Claude AI (much better quality)
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Optional: Job Board Search (Adzuna) ────────────────────────────────
# Sign up free at https://developer.adzuna.com — 250 searches/day free
# Searches Indeed, LinkedIn, ZipRecruiter, and more for each company's open roles
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=us

# ── Server ─────────────────────────────────────────────────────────────
PORT=3000
