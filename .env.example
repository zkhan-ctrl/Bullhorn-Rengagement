# ── CData Connect Cloud ────────────────────────────────────────────────
# Base OData URL for your BullhornCRM1 connection
CDATA_URL=https://cloud.cdata.com/api/odata/BullhornCRM1

# CData login email (the account that owns the connection)
CDATA_USER=vanessa.shuman@cgrteam.com

# Personal Access Token — generate at cloud.cdata.com → Settings → Personal Access Tokens
# NEVER commit this to GitHub
CDATA_PAT=your_personal_access_token_here

# ── Optional: AI Email Drafts ──────────────────────────────────────────
# If set, email drafts will be generated by Claude AI (much better quality)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Optional: Job Board Search (Adzuna) ────────────────────────────────
# Sign up free at https://developer.adzuna.com — 250 searches/day free
# Searches Indeed, LinkedIn, ZipRecruiter, and more
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=us

# ── Server ─────────────────────────────────────────────────────────────
PORT=3000
